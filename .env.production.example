ENVIRONMENT=production
AUTO_CREATE_SCHEMA=false

APP_DOMAIN=aiintelligencehub.duckdns.org
ACME_EMAIL=youremail@email.com
APP_BASE_URL=https://aiintelligencehub.duckdns.org
CORS_ORIGINS=https://aiintelligencehub.duckdns.org

POSTGRES_DB=ai_intelligence_hub
POSTGRES_USER=aihub
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://aihub:change-this-postgres-password@db:5432/ai_intelligence_hub

REDIS_URL=redis://redis:6379/0

SECRET_KEY=generate-a-long-random-secret
ACCESS_TOKEN_EXPIRE_HOURS=24
TRIGGER_DIGEST_TOKEN=generate-a-separate-random-trigger-token

GEMINI_API_KEY=
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
GROQ_API_KEY=
NEWS_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=updates@example.com

# Leave empty to disable MLflow in the low-cost production setup.
MLFLOW_TRACKING_URL=
